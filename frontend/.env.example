# Weft Contract Addresses
NEXT_PUBLIC_DEFAULT_CHAIN=sepolia

# Sepolia
NEXT_PUBLIC_WEFT_MILESTONE_SEPOLIA=
NEXT_PUBLIC_VERIFIER_REGISTRY_SEPOLIA=

# Base Sepolia
NEXT_PUBLIC_WEFT_MILESTONE_BASE_SEPOLIA=
NEXT_PUBLIC_VERIFIER_REGISTRY_BASE_SEPOLIA=

# Mainnet
NEXT_PUBLIC_WEFT_MILESTONE_MAINNET=
NEXT_PUBLIC_VERIFIER_REGISTRY_MAINNET=

# Base
NEXT_PUBLIC_WEFT_MILESTONE_BASE=
NEXT_PUBLIC_VERIFIER_REGISTRY_BASE=

# WalletConnect (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: frontend proxy target for the Python status API
WEFT_STATUS_API_URL=http://127.0.0.1:9010

# fal.ai — AI-woven textile swatch generation for milestone chronicle cards
# Get a key at https://fal.ai — used by the daemon to generate unique milestone images
NEXT_PUBLIC_FAL_IMAGE_URL=https://queue.fal.run