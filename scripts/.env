###############################################################################
# Weft verifier + status API environment
# NOTE: This file contains a PRIVATE KEY. Keep it secret and do not commit it.
# (It is gitignored by default: scripts/.env)
###############################################################################

# --- fal.ai (AI image generation for milestone swatches + chronicle covers) ---
FAL_KEY=REDACTED_FAL_KEY

# --- Wallet (generated) ---
VERIFIER_ADDRESS=0x80fD247281A198BA26716eac9FA842d9a428Ac04
VERIFIER_PRIVATE_KEY=REDACTED_PRIVATE_KEY

# Use the same funded key for deployments/admin actions (can be changed later).
DEPLOYER_KEY=REDACTED_PRIVATE_KEY
OWNER_ADDRESS=0x80fD247281A198BA26716eac9FA842d9a428Ac04
CHAIN_ID=16602

# --- Chain / contracts (fill these in after deploy) ---
# RPC endpoint for the chain where Weft contracts are deployed
ETH_RPC_URL=https://evmrpc-testnet.0g.ai

# Deployed WeftMilestone contract address
WEFT_CONTRACT_ADDRESS=0xcc768d56b0053b1b2df5391dde989be3f859474c

# Deployed VerifierRegistry contract address
VERIFIER_REGISTRY=0x599e34de50379c584787e0b7ba616ac9b6723169

# --- 0G indexer (required for metadata-driven verification) ---
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# --- Runtime flags (optional) ---
# PUBLISH_0G=1
# PUBLISH_0G_CONSENSUS=1
# PUBLISH_0G_BUNDLE=1

# --- Status API ---
STATUS_HOST=0.0.0.0
STATUS_PORT=9010
